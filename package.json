{
  "name": "hyeboard",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "pnpm --parallel --filter @hyeboard/web --filter @hyeboard/api dev",
    "dev:web": "pnpm --filter @hyeboard/web dev",
    "dev:api": "pnpm --filter @hyeboard/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
