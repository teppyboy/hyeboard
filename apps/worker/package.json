{
  "name": "@hyeboard/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --show-interactive-dev-session=false --log-level info",
    "deploy": "wrangler deploy",
    "serve:node": "tsx src/serve-node.ts",
    "serve:bun": "bun run src/serve-bun.ts",
    "wrangler": "wrangler",
    "build": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/node": "^1.4.5",
    "@hyeboard/core": "workspace:*",
    "@hyeboard/schemas": "workspace:*",
    "@hyeboard/university-adapters": "workspace:*",
    "@sinclair/typebox": "^0.34.49",
    "elysia": "^1.4.29",
    "openapi-types": "^12.1.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260629.1",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0"
  }
}
