# Copy to .env (Node) or rely on process.env (Bun) when running
# `pnpm --filter @hyeboard/worker serve:node` / `serve:bun`.
# Not used by `pnpm dev`/`wrangler deploy` — those read apps/worker/.dev.vars
# and wrangler secrets instead.

# 32+ random bytes, base64 is fine. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
HYEB_SESSION_SECRET=

# Comma-separated origins allowed via CORS. Only needed if the frontend is
# served from a different origin than this worker (same-origin needs none).
HYEB_ALLOWED_ORIGINS=

# Optional. CDP WebSocket endpoint for a self-hosted headless Chrome
# (see docker-compose.yml at the repo root), e.g. ws://localhost:3000.
# Required only for the UET Google-login automation feature; every other
# route works without it.
HYEB_BROWSER_WS_ENDPOINT=

# Optional (debug). Set HYEB_BROWSER_LOCAL=true to launch Chrome directly on
# your machine (headful, not headless). Requires a local Chrome/Chromium
# installation. Useful for debugging Google login automation interactively.
HYEB_BROWSER_LOCAL=

# Optional. Path to a local Chrome/Chromium executable, used only when
# HYEB_BROWSER_LOCAL=true (puppeteer-core does not bundle its own browser).
# e.g. C:\Program Files\Google\Chrome\Application\chrome.exe on Windows.
HYEB_CHROME_PATH=

# Optional. pino log level: trace | debug | info | warn | error | fatal |
# silent. Defaults to "info". Set to "debug" to see per-request logging and
# step-by-step UET Google-login automation traces. In dev (NODE_ENV !==
# "production") on plain Node, logs are pretty-printed via pino-pretty; Bun
# and production always get plain JSON lines.
HYEB_LOG_LEVEL=

# Optional. Requires `pnpm dev:node`/`dev:bun`/`build:node` (NOT `wrangler
# dev`/`deploy` — Cloudflare Workers cannot run Patchright at all) AND
# HYEB_BROWSER_LOCAL=true. Set to "true" to launch Chrome via Patchright
# (github.com/Kaliiiiiiiiii-Vinyzu/patchright-nodejs) instead of plain
# Puppeteer for the "local" browser connection — a patched Chromium launch
# with better anti-bot-detection stealth. Requires `npx patchright install
# chrome` to be run once first. Unverified against a real account; treat
# as experimental.
HYEB_BROWSER_PATCHRIGHT=

PORT=8787
