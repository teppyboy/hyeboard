# Copy to .env (Node) or rely on process.env (Bun) when running
# `pnpm --filter @hyeboard/worker serve:node` / `serve:bun`.
# Not used by `pnpm dev`/`wrangler deploy` — those read apps/worker/.dev.vars
# and wrangler secrets instead.

# 32+ random bytes, base64 is fine. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
HYEB_SESSION_SECRET=

# Comma-separated origins allowed via CORS. Only needed if the frontend is
# served from a different origin than this worker (same-origin needs none).
HYEB_ALLOWED_ORIGINS=

# Optional. CDP WebSocket endpoint for a self-hosted headless Chrome
# (see docker-compose.yml at the repo root), e.g. ws://localhost:3000.
# Required only for the UET Google-login automation feature; every other
# route works without it.
HYEB_BROWSER_WS_ENDPOINT=

PORT=8787
