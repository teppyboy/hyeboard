{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hyeboard-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-30",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  },
  "vars": {
    "HYEB_ALLOWED_ORIGINS": "http://localhost:5173,http://127.0.0.1:5173"
  },
  "secrets": {
    "required": ["HYEB_SESSION_SECRET"]
  }
}
